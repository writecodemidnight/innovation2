# 校园社团活动评估系统 - 前端环境变量配置

# ===========================================
# 开发环境配置
# ===========================================

# API基础URL
VITE_API_BASE_URL=http://localhost:8080/api

# 应用环境
development

# 微信小程序AppID（学生端需要）
VITE_WECHAT_APP_ID=your_wechat_app_id_here

# OSS配置（文件上传）
VITE_OSS_ENDPOINT=https://your-oss-endpoint.com
VITE_OSS_BUCKET=your-bucket-name

# ===========================================
# 生产环境配置 (.env.production)
# ===========================================

# VITE_API_BASE_URL=/api
# VITE_APP_ENV=production
